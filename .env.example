# Phase 1 uses public market data only.
# Do not add private keys, wallet seed phrases, withdrawal keys, or trading-enabled API keys.

APP_ENV=local
DATABASE_URL=sqlite:///./data/research.db
LOG_LEVEL=INFO

# Public market data settings
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Symbols are comma-separated.
OKX_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT

# Keywords used to filter Polymarket markets during discovery (comma-separated, case-insensitive).
POLYMARKET_CRYPTO_KEYWORDS=BTC,ETH,SOL,bitcoin,ethereum,solana,crypto,XRP,DOT

# Phase 1 safety controls
ALLOW_REAL_TRADING=false
ALLOW_PRIVATE_KEYS=false
ALLOW_WITHDRAWALS=false
ALLOW_BROWSER_AUTOMATION=false

